#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 not found. Install Python 3.10+ and rerun." >&2
  exit 1
fi

python3 "${ROOT_DIR}/scripts/bootstrap_env.py"
exec "${ROOT_DIR}/.venv/bin/python" -m busy_installer.app "$@"
